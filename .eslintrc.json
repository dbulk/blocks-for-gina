{
    "env": {
      "browser": true,
      "es2021": true
    },
    "extends": [
      "standard",
      "plugin:@typescript-eslint/recommended"
    ],
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {
      "semi": [2, "always"]
    }
  }